#include <bits/stdc++.h>
using namespace std;

#define all(x) x.begin(), x.end()
using ll = long long;
using pll = array<ll, 2>;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(0);

    ll n;
    cin >> n;

    vector<ll> a(n);

    for (ll i = 0; i < n; ++i) {
        cin >> a[i];
    }

    sort(all(a));

    ll ans = 0;

    for (ll i = 0; i < n - 2; ++i) {
        ll k = i + 2;

        for (ll j = i + 1; j < n - 1; ++j) {

            if (k < j + 1) {
                k = j + 1;
            }

            while (k < n && a[i] + a[j] > a[k]) {
                ++k;
            }

            ans += k - j - 1;
        }
    }

    cout << ans << "\n";

    return 0;
}
