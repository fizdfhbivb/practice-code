#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;
    
    vector<int> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    sort(a.begin(), a.end());
    
    int count = 0;
    for (int k = n - 1; k >= 2; k--) {
        int i = 0;
        int j = k - 1;
        while (i < j) {
            if (a[i] + a[j] > a[k]) {
                count += j - i;
                j--;
            } else {
                i++;
            }
        }
    }
    
    cout << count << endl;
    
    return 0;
}
